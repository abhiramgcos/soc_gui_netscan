# ─── Database ───────────────────────────────────
POSTGRES_DB=soc_network
POSTGRES_USER=soc_admin
POSTGRES_PASSWORD=changeme_in_production
DB_PORT=5434

# ─── API ────────────────────────────────────────
API_PORT=8001
API_WORKERS=2
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Worker ─────────────────────────────────────
WORKER_CONCURRENCY=4

# ─── Redis ──────────────────────────────────────
REDIS_PORT=6379

# ─── Frontend ───────────────────────────────────
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001

# ─── Firmware / EMBA / Ollama ─────────────────
EMBA_HOME=/opt/emba
EMBA_PATH=/opt/emba/emba
EMBA_TIMEOUT=7200
EMBA_GPT_LEVEL=1
SCAN_INTERFACE=eth0
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen3:4b
