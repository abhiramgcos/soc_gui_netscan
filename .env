# ─── Database ───────────────────────────────────
POSTGRES_DB=soc_network
POSTGRES_USER=soc_admin
POSTGRES_PASSWORD=changeme_in_production
DB_PORT=5434

# ─── API ────────────────────────────────────────
API_PORT=8001
API_WORKERS=2
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Worker ─────────────────────────────────────
WORKER_CONCURRENCY=4

# ─── Redis ──────────────────────────────────────
REDIS_PORT=6379

# ─── Frontend ───────────────────────────────────
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001

# ─── Firmware / EMBA / Ollama ─────────────────
EMBA_HOME=/opt/emba
EMBA_PATH=/opt/emba/emba
EMBA_HOST_PATH=/var/home/abhiramgcos/emba
EMBA_CONTAINER_NAME=soc_emba
EMBA_TIMEOUT=1800
EMBA_GPT_LEVEL=1
EMBA_PROFILE=default-scan.emba
EMBA_FAST_MODE=0
EMBA_MODULES=p05,s10,s20,s40
TRIAGE_MAX_FINDINGS=120
SCAN_INTERFACE=eth0
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5
# New pipeline settings (all have defaults, only override if needed)
PIPELINE_TIMEOUT=3600
DOWNLOAD_MAX_RETRIES=3
FIRMWARE_MIN_SIZE_BYTES=1000000
TRIAGE_NUM_PREDICT_STEPS=4096,2048,1024
ALERT_RISK_THRESHOLD=7.0
SLACK_WEBHOOK_URL=          # leave empty to disable
ALERT_EMAIL=                # leave empty to disable